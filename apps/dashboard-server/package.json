{
  "name": "@browsermesh/dashboard-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile-workflows": "vite build",
    "dev": "vite build && tsx watch src/index.ts",
    "start": "vite build && node dist/index.js",
    "build": "vite build && tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@browsermesh/compiler": "workspace:*",
    "@browsermesh/runtime-loader": "workspace:*",
    "@browsermesh/workflow": "workspace:*",
    "@browsermesh/workflow-builder": "workspace:*",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.7"
  }
}
