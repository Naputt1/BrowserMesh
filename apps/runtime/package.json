{
  "name": "@browsermesh/runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "browsermesh-runtime": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@browsermesh/workflow": "workspace:*",
    "@grpc/grpc-js": "^1.13.0",
    "@grpc/proto-loader": "^0.7.0",
    "cloakbrowser": "^0.3.0",
    "playwright-core": "^1.53.0"
  },
  "devDependencies": {
    "tsx": "^4.22.3",
    "typescript": "^5.8.0",
    "vitest": "^4.1.7"
  }
}
